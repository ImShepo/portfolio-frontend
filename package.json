{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "build:e2e": "CONTENT_FALLBACK_ENABLED=true next build",
    "start:e2e": "CONTENT_FALLBACK_ENABLED=true next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-content.ts",
    "audit": "npm audit --audit-level=high",
    "analyze": "ANALYZE=true next build",
    "verify": "npm run validate && npm run lint && npm run typecheck && npm run build",
    "test:e2e": "playwright test",
    "ci": "npm run validate && npm run verify && npm run test:e2e",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.108.0"
  }
}
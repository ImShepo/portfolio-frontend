# NestJS CMS backend origin ONLY (no /public or /api suffix).
# With Next.js on :3000, run the API on :3001 and set:
API_URL=http://localhost:3001

# If API_URL is unset in development, the app defaults to http://localhost:3001.

# ISR / fetch cache revalidation (seconds). Route segment revalidate is 60 in app routes — keep aligned.
REVALIDATE_SECONDS=60

# Shared secret with portfolio-admin — enables on-demand revalidation after CMS saves
REVALIDATE_SECRET=change-me-in-production

# false = API only (production). true = fall back to content/projects.json when API fails.
CONTENT_FALLBACK_ENABLED=false

# Static mode: true = serve all content from local JSON files (no backend needed).
# Use this for Cloudflare Pages or any deployment without a backend.
# When true, CONTENT_FALLBACK_ENABLED and API_URL are ignored.
STATIC_MODE=false
